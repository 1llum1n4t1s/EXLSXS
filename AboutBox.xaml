<Window x:Class="EXLSXS.AboutBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Height="300"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid Background="#F0F0F0" Margin="20">
        <StackPanel VerticalAlignment="Stretch">
            <!-- タイトル -->
            <TextBlock x:Name="ProductNameLabel"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#333333"
                       Text="Excel Finisher Add-in"
                       Margin="0,0,0,15" />

            <!-- バージョン -->
            <TextBlock x:Name="VersionLabel"
                       FontSize="12"
                       Foreground="#666666"
                       Text="Version 1.0.0.0"
                       Margin="0,0,0,15" />

            <!-- コピーライト -->
            <TextBlock x:Name="CopyrightLabel"
                       FontSize="11"
                       Foreground="#888888"
                       TextWrapping="Wrap"
                       Text="Copyright © 2024. All rights reserved."
                       Margin="0,0,0,15" />

            <!-- スペーサー -->
            <Border Height="1" Background="#CCCCCC" Margin="0,0,0,15" />

            <!-- ホームページリンク -->
            <TextBlock Margin="0,0,0,15">
                <Hyperlink x:Name="HomePageLink"
                           Foreground="#0066CC"
                           FontSize="11"
                           Click="HomePageLink_Click">
                    https://github.com/1llum1n4t1s/EXLSXS
                </Hyperlink>
            </TextBlock>

            <!-- フィラー -->
            <Border Margin="0,0,0,15" />

            <!-- OK ボタン -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="OKButton"
                        Click="OKButton_Click"
                        Content="OK"
                        Width="80"
                        Height="32"
                        Background="#007ACC"
                        Foreground="White"
                        FontSize="12"
                        Cursor="Hand" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
