<Window x:Class="EXLSXS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EXLSXS"
        mc:Ignorable="d"
        Title="Excel修復ツール" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- 左側：基本操作エリア -->
        <StackPanel Grid.Column="0">
            <!-- ファイル選択エリア -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="5" Padding="15" Background="#F9F9F9" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="FilePathTextBox" Grid.Column="0"
                             IsReadOnly="True" Margin="0,0,10,0"
                             VerticalAlignment="Center"
                             Text="Excelファイルを選択してください" />

                    <Button x:Name="BrowseButton" Grid.Column="1"
                            Content="ファイル選択" Width="100" Height="30"
                            Click="BrowseButton_Click" />
                </Grid>
            </Border>

            <!-- 操作オプション -->
            <GroupBox Header="修復・最適化オプション" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <CheckBox x:Name="OptimizeCheckBox" Content="ファイル最適化"
                              IsChecked="True" Margin="0,5" />
                    <CheckBox x:Name="PerformanceCheckBox" Content="パフォーマンス向上"
                              IsChecked="True" Margin="0,5" />
                    <CheckBox x:Name="CompressImagesCheckBox" Content="画像の圧縮"
                              IsChecked="False" Margin="0,5" />
                    <CheckBox x:Name="BackupOriginalCheckBox" Content="元ファイルのバックアップを作成"
                              IsChecked="True" Margin="0,5" />
                </StackPanel>
            </GroupBox>

            <!-- 実行ボタンとプログレスバー -->
            <StackPanel>
                <ProgressBar x:Name="ProgressBar" Height="20" Margin="0,0,0,10" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="ProcessButton" Content="実行"
                            Height="40" Width="120" FontSize="16" FontWeight="Bold"
                            Click="ProcessButton_Click" IsEnabled="False" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- 右側：ログ表示エリア -->
        <GroupBox Grid.Column="2" Header="処理ログ">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="LogTextBox" Grid.Row="0" 
                         IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11" 
                         Background="#F8F8F8" BorderThickness="1"
                         TextWrapping="Wrap"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                    <Button x:Name="ClearLogButton" Content="ログクリア" 
                            Width="80" Height="25" Margin="0,0,5,0" Click="ClearLogButton_Click"/>
                    <Button x:Name="CopyLogButton" Content="ログコピー" 
                            Width="80" Height="25" Click="CopyLogButton_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</Window>