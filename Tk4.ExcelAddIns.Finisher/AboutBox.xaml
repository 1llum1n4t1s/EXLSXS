<Window x:Class="Tk4.ExcelAddIns.Finisher.AboutBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Height="300"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid Background="#F0F0F0" Margin="20">
        <StackPanel VerticalAlignment="Stretch" Spacing="15">
            <!-- タイトル -->
            <TextBlock x:Name="ProductNameLabel"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#333333"
                       Text="Excel Finisher Add-in" />

            <!-- バージョン -->
            <TextBlock x:Name="VersionLabel"
                       FontSize="12"
                       Foreground="#666666"
                       Text="Version 1.0.0.0" />

            <!-- コピーライト -->
            <TextBlock x:Name="CopyrightLabel"
                       FontSize="11"
                       Foreground="#888888"
                       TextWrapping="Wrap"
                       Text="Copyright © 2024. All rights reserved." />

            <!-- スペーサー -->
            <Border Height="1" Background="#CCCCCC" />

            <!-- ホームページリンク -->
            <Hyperlink x:Name="HomePageLink"
                       Foreground="#0066CC"
                       FontSize="11"
                       Click="HomePageLink_Click">
                https://github.com/1llum1n4t1s/EXLSXS
            </Hyperlink>

            <!-- フィラー -->
            <Border />

            <!-- OK ボタン -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button x:Name="OKButton"
                        Click="OKButton_Click"
                        Content="OK"
                        Width="80"
                        Height="32"
                        Background="#007ACC"
                        Foreground="White"
                        FontSize="12"
                        Cursor="Hand" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
